4. Display the 5 numbers after 10 usong itertools. 

from itertools import count
for i in count(10, 1):
   if i>14: 
      break
   print(i,end=" " "\n")

5. Display the 3 cycle for [5,10,15]

from itertools import cycle
counter=0
for item in cycle([5,10,15]):
   print(item,end=" " "\n")
   counter+=1
   if counter>8:
      break

