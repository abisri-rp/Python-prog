def is_prime(n):
    if n < 2:
        return False
    for i in range(2, n):
        if n % i == 0:
            return False
    return True
abi_clubs = student_clubs["Abi"]
final_students = set()
for name in student_clubs:
    has_vowel_club = False
    for club in student_clubs[name]:
        if club[0].lower() in "aeiou":
            has_vowel_club = True
    if is_prime(len(name)) and has_vowel_club and student_clubs[name].isdisjoint(abi_clubs):
        final_students.add(name)
print("\n14. Final students satisfying all conditions:")
print(final_students)

